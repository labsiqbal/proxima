#!/usr/bin/env bash
# Forgot-password escape hatch (self-hosted single-user): clear the owner's
# password and revoke all sessions, so the next launch shows the "set a password"
# screen again. You have local machine/DB access — that IS the recovery path.
#
# Usage:
#   scripts/reset-password [path/to/proxima.db]
#   PROXIMA_DB_PATH=~/.local/share/proxima-dev/proxima-dev.db scripts/reset-password
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

DB="${PROXIMA_DB_PATH:-${1:-$HOME/.local/share/proxima/proxima.db}}"
if [ ! -f "$DB" ]; then
  echo "Database not found: $DB" >&2
  echo "Pass the path, or set PROXIMA_DB_PATH. (dev DB is usually ~/.local/share/proxima-dev/proxima-dev.db)" >&2
  exit 1
fi

PY="$ROOT/apps/api/.venv/bin/python"; [ -x "$PY" ] || PY=python3
"$PY" - "$DB" <<'PYEOF'
import sqlite3, sys
db = sys.argv[1]
conn = sqlite3.connect(db)
conn.execute("UPDATE users SET password_hash = NULL, password_set_at = NULL")
conn.execute("DELETE FROM auth_sessions")
conn.commit()
conn.close()
print(f"✓ Password cleared and all sessions revoked in {db}")
print("  Restart Proxima and you'll be prompted to set a new password.")
PYEOF
