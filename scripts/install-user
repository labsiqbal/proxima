#!/usr/bin/env bash
# One-command, no-sudo install: build the app, then run it as an always-on
# systemd *user* service (auto-starts on login/boot, restarts on crash) with a
# daily database backup timer. Re-runnable (idempotent).
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG_FILE="${PROXIMA_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/proxima/proxima.env}"
UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
DRY_RUN=0

case "${1:-}" in
  "") ;;
  --dry-run) DRY_RUN=1 ;;
  *) echo "usage: $0 [--dry-run]" >&2; exit 2 ;;
esac

run() {
  if [[ "$DRY_RUN" == 1 ]]; then
    printf '+ '
    printf '%q ' "$@"
    printf '\n'
  else
    "$@"
  fi
}

command -v uv  >/dev/null 2>&1 || { echo "missing: uv"  >&2; exit 1; }
command -v npm >/dev/null 2>&1 || { echo "missing: npm" >&2; exit 1; }

echo "==> Building backend deps"
if [[ "$DRY_RUN" == 1 ]]; then
  echo "+ (cd $ROOT/apps/api && uv sync)"
else
  ( cd "$ROOT/apps/api" && uv sync >/dev/null )
fi
echo "==> Building web PWA"
# Prefer npm ci: it installs exactly from the lockfile WITHOUT rewriting it, so a
# fresh build doesn't dirty package-lock.json and block the next 'git pull'. Fall
# back to npm install only if the lockfile has drifted (e.g. different npm version).
if [[ "$DRY_RUN" == 1 ]]; then
  echo "+ (cd $ROOT/apps/web && (npm ci || npm install) && npm run build)"
else
  ( cd "$ROOT/apps/web" && { npm ci >/dev/null 2>&1 || npm install >/dev/null; } && npm run build >/dev/null )
fi

echo "==> Writing config"
run bash "$ROOT/scripts/proxima" init-config

echo "==> Checking for Hermes runner"
if command -v hermes >/dev/null 2>&1 && { [ -f "${HERMES_HOME:-$HOME/.hermes}/auth.json" ] || [ -f "${HERMES_HOME:-$HOME/.hermes}/config.yaml" ]; }; then
  echo "    Hermes detected — Proxima will use your existing install."
else
  echo "    WARNING: Hermes not detected." >&2
  echo "    Proxima installs fine, but chats won't run until Hermes is set up:" >&2
  echo "      1) install the Hermes agent CLI (must be on PATH)" >&2
  echo "      2) run 'hermes -z' to authenticate" >&2
  echo "      3) restart: systemctl --user restart proxima" >&2
fi

# Bake node's bin dir into the service PATH so the spawned `hermes` agent (a node
# tool) resolves its runtime even under systemd's minimal environment.
NODE_BIN="$(dirname "$(command -v node 2>/dev/null || echo /usr/bin/node)")"
SVC_PATH="$NODE_BIN:$HOME/.local/bin:/home/linuxbrew/.linuxbrew/bin:/usr/local/bin:/usr/bin:/bin"

echo "==> Installing systemd user units -> $UNIT_DIR"
run mkdir -p "$UNIT_DIR"

if [[ "$DRY_RUN" == 1 ]]; then
  echo "+ write $UNIT_DIR/proxima.service"
else
  cat > "$UNIT_DIR/proxima.service" <<EOF
[Unit]
Description=Proxima self-hosted workspace
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$ROOT
Environment=PATH=$SVC_PATH
ExecStart=$ROOT/scripts/proxima serve
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
EOF
fi

if [[ "$DRY_RUN" == 1 ]]; then
  echo "+ write $UNIT_DIR/proxima-backup.service"
else
  cat > "$UNIT_DIR/proxima-backup.service" <<EOF
[Unit]
Description=Proxima database backup

[Service]
Type=oneshot
EnvironmentFile=-$CONFIG_FILE
ExecStart=$ROOT/scripts/backup
EOF
fi

if [[ "$DRY_RUN" == 1 ]]; then
  echo "+ write $UNIT_DIR/proxima-backup.timer"
else
  cat > "$UNIT_DIR/proxima-backup.timer" <<EOF
[Unit]
Description=Daily Proxima backup

[Timer]
OnCalendar=*-*-* 03:00:00
Persistent=true

[Install]
WantedBy=timers.target
EOF
fi

echo "==> Enabling services"
run systemctl --user daemon-reload
run systemctl --user enable proxima.service
# restart (not just enable --now) so re-running this to UPDATE actually loads
# the new code — enable --now is a no-op on an already-running unit.
run systemctl --user restart proxima.service
run systemctl --user enable --now proxima-backup.timer
# Keep the service running even when you're not logged in (best-effort).
if [[ "$DRY_RUN" == 1 ]]; then
  run loginctl enable-linger "$USER"
else
  loginctl enable-linger "$USER" >/dev/null 2>&1 || echo "   (note: enable-linger skipped — service runs while you're logged in)"
fi

# Put the `proxima` command on PATH so `proxima update` / `proxima restart`
# work from anywhere (not just ./scripts/proxima inside the checkout).
echo "==> Linking 'proxima' command into ~/.local/bin"
run mkdir -p "$HOME/.local/bin"
run ln -sf "$ROOT/scripts/proxima" "$HOME/.local/bin/proxima"
case ":$PATH:" in
  *":$HOME/.local/bin:"*) : ;;
  *) echo "   (note: add ~/.local/bin to your PATH to use the 'proxima' command)" ;;
esac

PORT="$( ( set +u; source "$CONFIG_FILE" 2>/dev/null; echo "${PROXIMA_PORT:-8765}" ) )"
if [[ "$DRY_RUN" == 1 ]]; then
  cat <<EOF

Dry run complete; no files or services changed.

   Source: $ROOT
   Config: $CONFIG_FILE
   Unit:   $UNIT_DIR/proxima.service
   URL:    http://127.0.0.1:$PORT
EOF
  exit 0
fi

cat <<EOF

✅ Proxima is installed and running as a service.

   Open:        http://127.0.0.1:$PORT      (first launch asks you to create the admin account)
   Update:      proxima update      (git pull + rebuild + restart)
   Restart:     proxima restart
   Status:      proxima status
   Logs:        proxima logs
   Stop:        proxima stop

   Phone / other devices over Tailscale (run once, persists):
     sudo tailscale set --operator=\$(whoami)   # one-time
     tailscale serve --bg $PORT
   then open your https MagicDNS URL and install the PWA.

   Backups run daily at 03:00 -> ~/.local/share/proxima/backups
EOF
