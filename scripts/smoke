#!/usr/bin/env node
/* eslint-disable no-console */
const { spawn } = require('node:child_process')
const fs = require('node:fs')
const http = require('node:http')
const net = require('node:net')
const os = require('node:os')
const path = require('node:path')

const BASE = process.env.PROXIMA_SMOKE_BASE || 'http://127.0.0.1:8767'
const SKIP_BROWSER = process.env.PROXIMA_SMOKE_SKIP_BROWSER === '1'

function request(path, { method = 'GET', body, headers = {} } = {}) {
  const url = new URL(path, BASE)
  const data = body === undefined ? undefined : Buffer.from(JSON.stringify(body))
  return new Promise((resolve, reject) => {
    const req = http.request(url, {
      method,
      headers: {
        'Content-Type': 'application/json',
        ...(data ? { 'Content-Length': data.length } : {}),
        ...headers,
      },
      timeout: 15000,
    }, res => {
      let raw = ''
      res.setEncoding('utf8')
      res.on('data', chunk => { raw += chunk })
      res.on('end', () => {
        let parsed = {}
        if (raw.trim()) {
          try { parsed = JSON.parse(raw) } catch (err) { return reject(new Error(`${method} ${path} returned invalid JSON: ${err.message}`)) }
        }
        if (res.statusCode < 200 || res.statusCode >= 300) {
          return reject(new Error(`${method} ${path} failed with ${res.statusCode}: ${raw.slice(0, 500)}`))
        }
        resolve({ status: res.statusCode, body: parsed })
      })
    })
    req.on('timeout', () => req.destroy(new Error(`${method} ${path} timed out`)))
    req.on('error', reject)
    if (data) req.write(data)
    req.end()
  })
}

function getJson(port, path) {
  return new Promise((resolve, reject) => {
    http.get({ host: '127.0.0.1', port, path }, res => {
      let raw = ''
      res.setEncoding('utf8')
      res.on('data', chunk => { raw += chunk })
      res.on('end', () => {
        try { resolve(JSON.parse(raw)) } catch (err) { reject(err) }
      })
    }).on('error', reject)
  })
}

const sleep = ms => new Promise(resolve => setTimeout(resolve, ms))

function freePort() {
  return new Promise((resolve, reject) => {
    const server = net.createServer()
    server.unref()
    server.on('error', reject)
    server.listen(0, '127.0.0.1', () => {
      const address = server.address()
      const port = typeof address === 'object' && address ? address.port : null
      server.close(() => port ? resolve(port) : reject(new Error('could not allocate a free port')))
    })
  })
}

async function apiSmoke() {
  let health
  for (let i = 0; i < 40; i += 1) {
    try {
      health = await request('/api/health')
      break
    } catch (err) {
      if (i === 39) throw err
      await sleep(250)
    }
  }
  if (!health.body.ok || health.body.database !== 'ok' || health.body.product !== 'proxima') {
    throw new Error(`unhealthy or wrong-product API: ${JSON.stringify(health.body)}`)
  }
  console.log('api: health ok (proxima)')

  const suppliedToken = process.env.PROXIMA_SMOKE_TOKEN || ''
  const password = process.env.PROXIMA_SMOKE_PASSWORD || ''
  const auth = suppliedToken
    ? { body: { token: suppliedToken, user: { username: 'token-authenticated owner' } } }
    : await request(password ? '/auth/login' : '/auth/auto', { method: 'POST', body: password ? { password } : {} })
  const token = auth.body.token
  if (!token || !auth.body.user?.username) throw new Error(`auth/auto returned unexpected payload: ${JSON.stringify(auth.body)}`)
  const headers = { Authorization: `Bearer ${token}` }
  console.log(`api: auth ok (${auth.body.user.username})`)

  const debug = await request('/api/debug/logs', { headers })
  if (!Array.isArray(debug.body.activeRuns) || !Array.isArray(debug.body.staleRuns)) throw new Error('debug logs missing activeRuns/staleRuns arrays')
  console.log(`api: debug logs ok (${debug.body.activeRuns.length} active, ${debug.body.staleRuns.length} stale)`)

  const dashboard = await request('/api/dashboard', { headers })
  if (typeof dashboard.body.counts?.activeRuns !== 'number') throw new Error('dashboard counts.activeRuns is not numeric')
  console.log('api: dashboard ok')

  const projects = await request('/api/projects', { headers })
  let project = projects.body.projects?.[0]
  let ownsProject = false
  if (!project?.slug) {
    const slug = `proxima-smoke-${Date.now()}`
    const createdProject = await request('/api/projects', {
      method: 'POST',
      headers,
      body: { slug, name: 'Proxima Smoke' },
    })
    project = createdProject.body
    if (!project?.slug) throw new Error(`temporary project create failed: ${JSON.stringify(createdProject.body)}`)
    ownsProject = true
    console.log(`api: temporary project created (${project.slug})`)
  }

  try {
    const smokeDir = `.proxima-smoke-${Date.now()}`
    const smokeFile = `${smokeDir}/note.md`
    const smokeRenamed = `${smokeDir}/renamed.md`
    const smokeWikiFile = `wiki/${smokeDir}/index.md`
    try {
      await request(`/api/projects/${encodeURIComponent(project.slug)}/file?path=${encodeURIComponent(smokeFile)}`, {
        method: 'PUT',
        headers,
        body: { content: '# Smoke\n\nok' },
      })
      const readBack = await request(`/api/projects/${encodeURIComponent(project.slug)}/file?path=${encodeURIComponent(smokeFile)}`, { headers })
      if (readBack.body.content !== '# Smoke\n\nok') throw new Error('file smoke read-back mismatch')
      await request(`/api/projects/${encodeURIComponent(project.slug)}/fs/rename`, {
        method: 'POST',
        headers,
        body: { from: smokeFile, to: smokeRenamed },
      })
      const tree = await request(`/api/projects/${encodeURIComponent(project.slug)}/tree?path=${encodeURIComponent(smokeDir)}`, { headers })
      if (!tree.body.entries?.some(e => e.name === 'renamed.md')) throw new Error('file smoke renamed entry missing from tree')
      await request(`/api/projects/${encodeURIComponent(project.slug)}/file?path=${encodeURIComponent(smokeWikiFile)}`, {
        method: 'PUT',
        headers,
        body: { content: '# Smoke Wiki\n\n[[renamed]]' },
      })
      const wiki = await request(`/api/projects/${encodeURIComponent(project.slug)}/wiki/all`, { headers })
      if (!wiki.body.notes?.some(n => n.path === `${smokeDir}/index.md` && n.content.includes('Smoke Wiki'))) throw new Error('wiki smoke note missing from bulk load')
      console.log('api: file write/read/rename/tree + wiki bulk ok')
    } finally {
      await request(`/api/projects/${encodeURIComponent(project.slug)}/fs?path=${encodeURIComponent(smokeDir)}`, { method: 'DELETE', headers, body: {} }).catch(() => {})
      await request(`/api/projects/${encodeURIComponent(project.slug)}/fs?path=${encodeURIComponent(`wiki/${smokeDir}`)}`, { method: 'DELETE', headers, body: {} }).catch(() => {})
    }

    const workflowName = `Smoke Workflow ${Date.now()}`
    const created = await request('/api/workflows', {
      method: 'POST',
      headers,
      body: { name: workflowName, project_slug: project.slug, steps: [{ name: 'Check', prompt: 'Return ok' }] },
    })
    if (!created.body.id) throw new Error(`workflow create missing id: ${JSON.stringify(created.body)}`)
    const workflowId = created.body.id

    try {
      const list = await request(`/api/workflows?project_slug=${encodeURIComponent(project.slug)}`, { headers })
      if (!list.body.some(row => row.id === workflowId)) throw new Error('created workflow was not returned by list endpoint')
      console.log(`api: workflow create/list ok (${workflowId})`)
    } finally {
      const deleted = await request(`/api/workflows/${workflowId}`, { method: 'DELETE', headers, body: {} })
      if (!deleted.body.ok) throw new Error(`workflow delete failed: ${JSON.stringify(deleted.body)}`)
      console.log(`api: workflow delete ok (${workflowId})`)
    }
  } finally {
    if (ownsProject) {
      await request(`/api/projects/${encodeURIComponent(project.slug)}`, { method: 'DELETE', headers, body: {} })
      console.log(`api: temporary project deleted (${project.slug})`)
    }
  }
  return token
}

async function waitForTarget(port) {
  for (let i = 0; i < 80; i += 1) {
    try {
      const pages = await getJson(port, '/json')
      const page = pages.find(p => p.type === 'page' && p.url?.startsWith(BASE))
      if (page?.webSocketDebuggerUrl) return page.webSocketDebuggerUrl
    } catch {}
    await sleep(250)
  }
  throw new Error(`Chrome DevTools target for ${BASE} was not ready`)
}

async function browserNavigationSmoke({ name, width, height, port, mobile, token }) {
  const userDataDir = fs.mkdtempSync(path.join(os.tmpdir(), `proxima-smoke-${name}-`))
  const chrome = spawn('google-chrome', [
    '--headless=new',
    '--disable-gpu',
    '--no-sandbox',
    '--disable-dev-shm-usage',
    `--user-data-dir=${userDataDir}`,
    `--remote-debugging-port=${port}`,
    `--window-size=${width},${height}`,
    BASE,
  ], { stdio: ['ignore', 'ignore', 'pipe'] })
  let stderr = ''
  chrome.stderr.on('data', chunk => { stderr += chunk.toString() })

  try {
    const wsUrl = await waitForTarget(port)
    const ws = new WebSocket(wsUrl)
    let id = 0
    const pending = new Map()
    const clientErrors = []
    ws.onmessage = event => {
      const message = JSON.parse(event.data)
      if (message.method === 'Runtime.exceptionThrown') clientErrors.push(message.params.exceptionDetails?.text || message.params.exceptionDetails?.exception?.description || 'Runtime exception')
      if (message.method === 'Runtime.consoleAPICalled' && message.params.type === 'error') clientErrors.push(message.params.args?.map(a => a.value || a.description || '').join(' ') || 'console.error')
      if (!message.id || !pending.has(message.id)) return
      const { resolve, reject } = pending.get(message.id)
      pending.delete(message.id)
      message.error ? reject(new Error(JSON.stringify(message.error))) : resolve(message.result)
    }
    await new Promise((resolve, reject) => { ws.onopen = resolve; ws.onerror = reject })
    const send = (method, params = {}) => new Promise((resolve, reject) => {
      const message = { id: ++id, method, params }
      pending.set(message.id, { resolve, reject })
      ws.send(JSON.stringify(message))
    })

    await send('Runtime.enable')
    await send('Page.enable')
    await send('Network.enable')
    await send('Network.setCookie', {
      name: 'proxima_session',
      value: token,
      url: BASE,
      httpOnly: true,
      sameSite: 'Lax',
    })
    if (mobile) {
      await send('Emulation.setDeviceMetricsOverride', {
        width,
        height,
        deviceScaleFactor: 2,
        mobile: true,
      })
    }
    await send('Page.navigate', { url: BASE })
    await sleep(2500)
    const result = await send('Runtime.evaluate', {
      awaitPromise: true,
      returnByValue: true,
      expression: `(${async function (mobile) {
        const wait = ms => new Promise(resolve => setTimeout(resolve, ms))
        const body = () => document.body.innerText || ''
        const disabledLabels = new Set(['Design', 'Design Studio'])
        const visibleDisabledNav = [...document.querySelectorAll('.sidebar button, .sidebar a')]
          .map(node => (node.textContent || '').trim())
          .filter(label => disabledLabels.has(label))
        if (visibleDisabledNav.length) throw new Error(`disabled navigation visible: ${visibleDisabledNav.join(', ')}`)
        async function openMobileMenu() {
          if (!mobile || document.querySelector('.sidebar.is-open')) return
          const menu = document.querySelector('[aria-label="Menu"]')
          if (!menu) throw new Error('missing mobile menu button')
          menu.click()
          for (let i = 0; i < 20; i += 1) {
            await wait(100)
            if (document.querySelector('.sidebar.is-open')) return
          }
          throw new Error('mobile menu did not open')
        }
        async function clickLabel(label, expect) {
          await openMobileMenu()
          let el = null
          for (let i = 0; i < 40; i += 1) {
            const scope = mobile ? document.querySelector('.sidebar.is-open') || document : document
            el = [...scope.querySelectorAll('button, [role="button"], a')].find(node => (node.textContent || '').trim().includes(label))
            if (el) break
            await wait(150)
          }
          if (!el) throw new Error(`missing nav ${label}\n${body().slice(0, 500)}`)
          el.click()
          for (let i = 0; i < 40; i += 1) {
            await wait(150)
            if (body().includes(expect)) return `${label}:ok`
          }
          throw new Error(`${label} did not show ${expect}\\n${body().slice(0, 500)}`)
        }
        async function clickDesktopSettings() {
          if (mobile) return null
          const account = document.querySelector('[aria-label="Account"]')
          if (!account) throw new Error(`missing account menu\\n${body().slice(0, 500)}`)
          account.click()
          let settings = null
          for (let i = 0; i < 20; i += 1) {
            await wait(100)
            settings = [...document.querySelectorAll('.user-menu button, button')].find(node => (node.textContent || '').trim().includes('Settings'))
            if (settings) break
          }
          if (!settings) throw new Error(`missing settings menu item\\n${body().slice(0, 500)}`)
          settings.click()
          for (let i = 0; i < 40; i += 1) {
            await wait(150)
            const heading = document.querySelector('.settings-content-head h2')
            if ((heading?.textContent || '').trim() !== 'Account & Preferences') continue
            async function clickSettingsSection(label, expect) {
              const section = [...document.querySelectorAll('.settings-menu-item')]
                .find(node => (node.textContent || '').includes(label))
              if (!section) throw new Error('missing settings section ' + label)
              section.click()
              for (let j = 0; j < 40; j += 1) {
                await wait(150)
                if (body().includes(expect)) return
              }
              throw new Error(label + ' did not show ' + expect)
            }
            await clickSettingsSection('Agents & Collaboration', 'Agent goals')
            await clickSettingsSection('Diagnostics', 'Debug logs')
            return 'Settings:ok'
          }
          throw new Error(`Settings did not show\\n${body().slice(0, 500)}`)
        }
        const checks = [
          await clickLabel('Wiki', 'Wiki'),
          await clickLabel('Artifacts', 'Artifacts'),
          await clickLabel('Workflows', 'Workflows'),
          await clickLabel('Activity', 'Activity'),
          await clickLabel('Terminal', 'Terminal 1'),
        ]
        const settings = await clickDesktopSettings()
        if (settings) checks.push(settings)
        return JSON.stringify(checks)
      }})(${JSON.stringify(mobile)})`,
    })
    const rawChecks = result.result.value
    const checks = typeof rawChecks === 'string' ? JSON.parse(rawChecks) : rawChecks
    const expectedChecks = mobile ? 5 : 6
    if (!Array.isArray(checks) || checks.length !== expectedChecks || checks.some(check => typeof check !== 'string' || !check.endsWith(':ok'))) {
      throw new Error(`unexpected browser check result: ${JSON.stringify({ checks, result })}`)
    }
    if (clientErrors.length) throw new Error(`browser client errors:\n${clientErrors.join('\n')}`)
    console.log(`browser:${name}: lazy navigation ok ${JSON.stringify(checks)}`)
    ws.close()
  } catch (err) {
    const hint = stderr.split('\n').filter(Boolean).slice(-5).join('\n')
    throw new Error(`${err.message}${hint ? `\nChrome stderr:\n${hint}` : ''}`)
  } finally {
    chrome.kill('SIGTERM')
    await sleep(300)
    fs.rmSync(userDataDir, { recursive: true, force: true })
  }
}

async function browserSmoke(token) {
  if (SKIP_BROWSER) {
    console.log('browser: skipped (PROXIMA_SMOKE_SKIP_BROWSER=1)')
    return
  }
  if (typeof WebSocket === 'undefined') throw new Error('browser smoke needs a Node runtime with global WebSocket')

  const configuredPort = process.env.PROXIMA_SMOKE_CDP_PORT ? Number(process.env.PROXIMA_SMOKE_CDP_PORT) : null
  const desktopPort = configuredPort || await freePort()
  const mobilePort = configuredPort ? configuredPort + 1 : await freePort()
  await browserNavigationSmoke({ name: 'desktop', width: 1280, height: 900, port: desktopPort, mobile: false, token })
  await browserNavigationSmoke({ name: 'mobile', width: 390, height: 844, port: mobilePort, mobile: true, token })
}

async function main() {
  console.log(`smoke: ${BASE}`)
  const token = await apiSmoke()
  await browserSmoke(token)
  console.log('smoke: ok')
}

main().catch(err => {
  console.error(`smoke: failed\n${err.stack || err.message}`)
  process.exitCode = 1
})
