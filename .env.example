# Proxima self-hosted install config
# Copy to ~/.config/proxima/proxima.env or /etc/proxima/proxima.env

PROXIMA_REPO_ROOT="/opt/proxima"
PROXIMA_CONFIG="/etc/proxima/proxima.env"
PROXIMA_DATA_DIR="/var/lib/proxima"
PROXIMA_DB_PATH="/var/lib/proxima/proxima.db"
PROXIMA_WORKSPACE_ROOT="/var/lib/proxima/workspace"
PROXIMA_HERMES_PROFILES_ROOT="/var/lib/proxima/hermes-profiles"
PROXIMA_WEB_DIST="/opt/proxima/apps/web/dist"
PROXIMA_HOST="127.0.0.1"
PROXIMA_PORT="8765"
PROXIMA_SERVICE_NAME="proxima"
PROXIMA_UPDATE_REPO="labsiqbal/proxima"

# Design Studio is on by default; set to 0 as an owner escape hatch.
PROXIMA_FEATURE_DESIGN_STUDIO="1"
# Graph workflows are the primary workflow authoring surface. Set to 0 only as a
# recovery switch when diagnosing graph-specific problems.
PROXIMA_FEATURE_WORKFLOW_GRAPH="1"

# Child-process guardrails. Agent runners receive only platform basics plus common
# provider API keys; app previews receive platform basics only. Add comma-separated
# names when a trusted local setup needs more. Full inheritance is an explicit
# compatibility escape hatch and is not recommended.
PROXIMA_RUNNER_ENV_ALLOWLIST=""
PROXIMA_APP_ENV_ALLOWLIST=""
PROXIMA_RUNNER_INHERIT_ENV="0"
PROXIMA_APP_INHERIT_ENV="0"

# Single-user installs use this no-op helper unless real filesystem ACLs are configured.
# Remove or replace with infra/scripts/projectctl when enabling real filesystem ACLs.
PROXIMA_PROJECTCTL_COMMAND="/usr/bin/true"

# Optional run settings
PROXIMA_RUN_TIMEOUT_SECONDS="300"
PROXIMA_RUN_WORKER_POLL_MS="250"
PROXIMA_MAX_UPLOAD_MB="100"
